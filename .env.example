# Required: GitHub token with billing read permissions
GITHUB_TOKEN=

# Choose one scope:
# Enterprise slug (preferred for per-user ranking)
ENTERPRISE_SLUG=
# Or organization name
ORG_NAME=

# Optional: included Premium Requests quota per user per billing cycle.
# Legacy PRU mode only. Ignored by AI Credits billing summaries.
INCLUDED_QUOTA=300

# Optional filters
PRODUCT=Copilot
MODEL=

# Optional: force which users are included in ranking, comma-separated.
# Useful when enterprise API cannot enumerate users due token permissions.
USER_LIST=

# Optional: one or more org names under enterprise, comma-separated.
# Used to enumerate users from org members when ENTERPRISE_SLUG is set.
ORG_LIST=

# Optional: cap user count for fallback per-user querying.
MAX_USERS=300

# Optional if you are using GHE.com
# Example: https://api.<subdomain>.ghe.com
GITHUB_API_BASE=https://api.github.com

# Optional: GitHub REST API version header.
# Keep the current default unless GitHub publishes a newer required version.
GITHUB_API_VERSION=2026-03-10

# Optional: Copilot billing model.
# auto       = use legacy_pru before 2026-06, ai_credits from 2026-06 onward
# legacy_pru = request-based Premium Request compatibility mode
# ai_credits = usage-based billing mode using enhanced billing netAmount
BILLING_MODEL=auto

PORT=3000

# Optional: cache TTL in seconds for API responses (default: 300 = 5 minutes)
CACHE_TTL=300

# Optional: Copilot service start date (YYYY-MM-DD). Days before this date
# are expected to have no data, preventing "cycle incomplete" false negatives.
# Example: COPILOT_START_DATE=2026-04-20
COPILOT_START_DATE=
