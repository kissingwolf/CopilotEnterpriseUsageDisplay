# =========================
# Required
# =========================

# GitHub PAT with enterprise billing read permission.
# Default: none (must set)
# Example: GITHUB_TOKEN=github_pat_xxx
GITHUB_TOKEN=

# Scope selector (set one of ENTERPRISE_SLUG / ORG_NAME; enterprise mode preferred).
# Default: empty
# Example: ENTERPRISE_SLUG=your-enterprise
ENTERPRISE_SLUG=

# Alternative scope when not using enterprise slug.
# Default: empty
# Example: ORG_NAME=your-org
ORG_NAME=


# =========================
# Billing period and filters
# =========================

# Billing year override.
# Default: current UTC year
# Example: BILLING_YEAR=2026
BILLING_YEAR=

# Billing month override (1-12).
# Default: current UTC month
# Example: BILLING_MONTH=6
BILLING_MONTH=

# Billing day override (mainly for date label / single-day query helper).
# Default: empty (not set)
# Example: BILLING_DAY=20
BILLING_DAY=

# Product filter passed to usage query.
# Default: empty in code; project convention uses Copilot
# Example: PRODUCT=Copilot
PRODUCT=Copilot

# Model filter (optional).
# Default: empty
# Example: MODEL=gpt-4o-copilot
MODEL=

# Copilot billing model.
# Default: auto
# Example: BILLING_MODEL=ai_credits
# Values: auto | legacy_pru | ai_credits
BILLING_MODEL=auto

# Legacy PRU included quota per user per cycle.
# Default: 300
# Example: INCLUDED_QUOTA=300
INCLUDED_QUOTA=300

# AI Credits fallback unit price (USD / credit) when API price is absent.
# Default: 0.01
# Example: AI_CREDIT_PRICE_FALLBACK=0.0125
AI_CREDIT_PRICE_FALLBACK=0.01

# Business seat base cost used as amount floor in ranking (USD).
# Default: 19
# Example: BUSINESS_SEAT_BASE_COST=19
BUSINESS_SEAT_BASE_COST=19

# Enterprise seat base cost used as amount floor in ranking (USD).
# Default: 39
# Example: ENTERPRISE_SEAT_BASE_COST=39
ENTERPRISE_SEAT_BASE_COST=39

# Copilot enable date, used to avoid false "cycle incomplete" before adoption.
# Default: empty (disabled)
# Example: COPILOT_START_DATE=2026-04-20
COPILOT_START_DATE=


# =========================
# Server and GitHub API
# =========================

# HTTP port.
# Default: 3000
# Example: PORT=3001
PORT=3000

# In-memory refresh cache TTL (seconds).
# Default: 300
# Example: CACHE_TTL=600
CACHE_TTL=300

# GitHub API base URL.
# Default: https://api.github.com
# Example: GITHUB_API_BASE=https://api.<subdomain>.ghe.com
GITHUB_API_BASE=https://api.github.com

# GitHub REST API version header value.
# Default: 2026-03-10
# Example: GITHUB_API_VERSION=2026-06-01
GITHUB_API_VERSION=2026-03-10

# Max concurrent GitHub API requests.
# Default: 3
# Example: GITHUB_MAX_CONCURRENT=5
GITHUB_MAX_CONCURRENT=3

# Max retries for GitHub API rate-limit / transient failures.
# Default: 3
# Example: GITHUB_MAX_RETRIES=5
GITHUB_MAX_RETRIES=3


# =========================
# Scheduler
# =========================

# Disable scheduler on this instance when set to true.
# Default: false (scheduler enabled)
# Example: SCHED_DISABLED=true
SCHED_DISABLED=false

# Daily local-time schedule list (HH:MM, comma-separated).
# Default: 03:00,12:00
# Example: SCHED_DAILY_TIMES=02:00,08:00,20:00
SCHED_DAILY_TIMES=03:00,12:00

# Extra backfill days on each run (today is always included).
# Default: 2
# Example: SCHED_BACKFILL_DAYS=3
SCHED_BACKFILL_DAYS=2

# Startup delay before first refresh (ms).
# Default: 5000
# Example: SCHED_STARTUP_DELAY_MS=15000
SCHED_STARTUP_DELAY_MS=5000


# =========================
# Logging / runtime
# =========================

# Node environment.
# Default: development (when not set)
# Example: NODE_ENV=production
NODE_ENV=development

# Log level for pino logger.
# Default: debug in development, info in production
# Example: LOG_LEVEL=info
# Values: trace | debug | info | warn | error
LOG_LEVEL=debug


# =========================
# Legacy / compatibility placeholders
# =========================

# The following vars are kept for compatibility with older deployments.
# Current code does not actively read them.

# Example: USER_LIST=alice,bob,charlie
USER_LIST=

# Example: ORG_LIST=org-a,org-b
ORG_LIST=

# Example: MAX_USERS=300
MAX_USERS=
